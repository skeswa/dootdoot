{
  "name": "dootdoot-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:wasm": "wasm-pack build dootdoot-core --target web --out-dir ../docs/.vitepress/wasm --out-name dootdoot_core --release --no-pack",
    "docs:build": "npm run docs:wasm && vitepress build docs",
    "docs:dev": "npm run docs:wasm && vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "test:docs": "npm run docs:build && node --test tests/docs-site.test.mjs"
  },
  "devDependencies": {
    "@fontsource/chakra-petch": "5.2.7",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "jsdom": "29.1.1",
    "mermaid": "11.16.0",
    "vitepress": "2.0.0-alpha.18",
    "vue": "3.5.39",
    "yaml": "2.9.0"
  }
}
